    package="com.systemdebugger.googlesansroundedoverlay"
    android:versionCode="1"
    android:versionName="1.0" >

    <uses-sdk
        android:minSdkVersion="29"
        android:targetSdkVersion="34" />

    <!-- Framework overlay -->
    <overlay
        android:isStatic="true"
        android:priority="1"
        android:targetPackage="android" />

    <!-- SystemUI overlay -->
